# Admin Panel Environment Variables
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# API Access Key (for Admin API authentication)
API_ACCESS_KEY=your-admin-api-key-here

# Database
DATABASE_PATH=/app/data/admin.db

# Docker Configuration
DOCKER_SOCKET_PATH=/var/run/docker.sock

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Pool Configuration
POOL_SIZE=5
POOL_IMAGE=claude-ws:latest
POOL_BASE_PORT=30000
IDLE_TIMEOUT_SECONDS=86400
POOL_DOCKER_NETWORK=claude-network

# Shared LLM Proxy for project containers
SHARED_LLM_PROXY_PORT=8666
SHARED_LLM_PROXY_URL=http://shared-llm-proxy:8666/api/proxy/anthropic
# ANTHROPIC_PROXIED_BASE_URL=https://api.anthropic.com
